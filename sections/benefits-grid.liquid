{{ 'section-benefits.css' | asset_url | stylesheet_tag }}

<section
  class="benefits section-spacing"
  id="benefits-{{ section.id }}"
  style="
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-heading" data-animate>{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="section-subheading" data-animate>{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="benefits__grid grid grid--3">
      {%- for block in section.blocks -%}
        <div class="benefits__item" data-animate {{ block.shopify_attributes }}>
          <div class="benefits__icon" style="color: {{ block.settings.icon_color }};">
            {%- if block.settings.custom_icon != blank -%}
              <img
                src="{{ block.settings.custom_icon | image_url: width: 96 }}"
                alt="{{ block.settings.title }}"
                width="48"
                height="48"
                loading="lazy"
              >
            {%- else -%}
              {%- case block.settings.icon -%}
                {%- when 'grip' -%}
                  {% render 'icon-grip', color: block.settings.icon_color %}
                {%- when 'snap-fit' -%}
                  {% render 'icon-snap-fit', color: block.settings.icon_color %}
                {%- when 'drip-free' -%}
                  {% render 'icon-drip-free', color: block.settings.icon_color %}
                {%- when 'shield' -%}
                  {% render 'icon-shield', color: block.settings.icon_color %}
                {%- when 'truck' -%}
                  {% render 'icon-truck', color: block.settings.icon_color %}
                {%- else -%}
                  {% render 'icon-grip', color: block.settings.icon_color %}
              {%- endcase -%}
            {%- endif -%}
          </div>
          <h3 class="benefits__title">{{ block.settings.title }}</h3>
          <p class="benefits__text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefits Grid",
  "tag": "div",
  "class": "benefits-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Choose SprayPro?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Designed to make spray painting easier, cleaner, and more comfortable."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F9FAFB"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "grip", "label": "Grip / Hand" },
            { "value": "snap-fit", "label": "Snap-Fit / Gear" },
            { "value": "drip-free", "label": "Drip-Free / Clean" },
            { "value": "shield", "label": "Shield / Guarantee" },
            { "value": "truck", "label": "Shipping Truck" }
          ],
          "default": "grip"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom icon image (overrides icon selector)"
        },
        {
          "type": "color",
          "id": "icon_color",
          "label": "Icon color",
          "default": "#DC2626"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Describe the feature benefit here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits Grid",
      "category": "Features",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "grip",
            "title": "Ergonomic Anti-Slip Grip",
            "text": "Fits naturally in your hand for maximum control and comfort during long painting sessions. Say goodbye to finger cramps."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "snap-fit",
            "title": "Universal Snap-On Fit",
            "text": "Easily attaches and securely locks onto almost any standard aerosol spray can in seconds."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "drip-free",
            "title": "Mess-Free Application",
            "text": "Keep your hands entirely clean, avoid accidental drips, and ensure an even, flawless coat every time."
          }
        }
      ]
    }
  ]
}
{% endschema %}
