<section class="collection-page section-spacing">
  <div class="page-width">
    <h1 class="section-heading">{{ collection.title }}</h1>

    {%- if collection.description != blank -%}
      <p class="section-subheading">{{ collection.description }}</p>
    {%- endif -%}

    {%- if collection.products.size > 0 -%}
      <div class="grid grid--3" style="margin-top:2rem">
        {%- for product in collection.products -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="collection-page__pagination" style="text-align:center;margin-top:3rem">
          {{ paginate | default_pagination }}
        </div>
      {%- endif -%}
    {%- else -%}
      <p style="text-align:center;color:var(--color-text-secondary);padding:3rem 0">
        No products found in this collection.
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection Page",
  "tag": "div",
  "class": "collection-section",
  "settings": []
}
{% endschema %}
