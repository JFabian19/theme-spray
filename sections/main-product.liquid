{{ 'section-product.css' | asset_url | stylesheet_tag }}

{%- assign product = product -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

<section class="product-page section-spacing" id="product-{{ section.id }}">
  <div class="page-width">
    <div class="product-page__grid">
      {%- comment -%} ===== GALLERY ===== {%- endcomment -%}
      <div class="product-page__gallery" data-animate>
        <div class="product-page__main-image-wrap">
          {%- if product.featured_image -%}
            <img
              id="ProductMainImage"
              class="product-page__main-image"
              src="{{ product.featured_image | image_url: width: 1200 }}"
              alt="{{ product.featured_image.alt | escape }}"
              width="1200"
              height="{{ 1200 | divided_by: product.featured_image.aspect_ratio | round }}"
              loading="eager"
            >
          {%- else -%}
            <div class="product-page__placeholder">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}

          {%- if current_variant.compare_at_price > current_variant.price -%}
            {%- assign discount = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round -%}
            <span class="product-page__badge badge badge--sale">Save {{ discount }}%</span>
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div class="product-page__thumbnails">
            {%- for image in product.images -%}
              <button
                class="product-page__thumb{% if forloop.first %} is-active{% endif %}"
                data-thumb-index="{{ forloop.index0 }}"
                data-full-src="{{ image | image_url: width: 1200 }}"
                aria-label="View image {{ forloop.index }}"
              >
                <img
                  src="{{ image | image_url: width: 200 }}"
                  alt="{{ image.alt | escape }}"
                  width="80"
                  height="80"
                  loading="lazy"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ===== PRODUCT INFO ===== {%- endcomment -%}
      <div class="product-page__info" data-animate>
        {%- comment -%} Title {%- endcomment -%}
        <h1 class="product-page__title">{{ product.title }}</h1>

        {%- comment -%} Price {%- endcomment -%}
        <div class="product-page__price-wrap">
          <span class="product-page__price" data-product-price>
            {{ current_variant.price | money }}
          </span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="product-page__compare-price" data-compare-price>
              {{ current_variant.compare_at_price | money }}
            </span>
            <span class="product-page__save badge badge--sale">
              You save {{ current_variant.compare_at_price | minus: current_variant.price | money }}
            </span>
          {%- else -%}
            <span class="product-page__compare-price" data-compare-price style="display:none"></span>
          {%- endif -%}
        </div>

        {%- comment -%} Short description {%- endcomment -%}
        {%- if section.settings.show_short_desc and product.description != blank -%}
          <div class="product-page__short-desc">
            {{ product.description | truncatewords: 30 }}
          </div>
        {%- endif -%}

        {%- comment -%} Variant Selector {%- endcomment -%}
        {%- if product.has_only_default_variant == false -%}
          <div class="product-page__variants">
            {%- for option in product.options_with_values -%}
              <div class="product-page__option">
                <label class="product-page__option-label" for="Option-{{ section.id }}-{{ forloop.index0 }}">
                  {{ option.name }}
                </label>
                <select
                  id="Option-{{ section.id }}-{{ forloop.index0 }}"
                  class="product-page__option-select"
                  data-variant-select
                >
                  {%- for value in option.values -%}
                    <option
                      value="{{ value }}"
                      {% if option.selected_value == value %}selected{% endif %}
                    >
                      {{ value }}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} Add to Cart Form {%- endcomment -%}
        <form method="post" action="/cart/add" data-add-to-cart class="product-page__form">
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          {%- comment -%} Quantity {%- endcomment -%}
          <div class="product-page__qty-row">
            <label class="product-page__option-label">Quantity</label>
            <div class="quantity-selector">
              <button type="button" class="quantity-selector__btn" data-qty-minus aria-label="Decrease quantity">−</button>
              <input
                type="number"
                name="quantity"
                class="quantity-selector__input"
                value="1"
                min="1"
                aria-label="Quantity"
              >
              <button type="button" class="quantity-selector__btn" data-qty-plus aria-label="Increase quantity">+</button>
            </div>
          </div>

          {%- comment -%} Add to Cart Button {%- endcomment -%}
          <button
            type="submit"
            class="btn btn--primary btn--large btn--full product-page__add-btn"
            data-add-btn
            {% unless current_variant.available %}disabled{% endunless %}
          >
            {%- if current_variant.available -%}
              {{ 'products.product.add_to_cart' | t }}
            {%- else -%}
              {{ 'products.product.sold_out' | t }}
            {%- endif -%}
          </button>

          {%- comment -%} Dynamic Checkout {%- endcomment -%}
          {%- if section.settings.show_dynamic_checkout -%}
            <div class="product-page__dynamic-checkout">
              {{ form | payment_button }}
            </div>
          {%- endif -%}
        </form>

        {%- comment -%} Trust blocks {%- endcomment -%}
        <div class="product-page__trust">
          {%- for block in section.blocks -%}
            {%- if block.type == 'trust_item' -%}
              <div class="product-page__trust-item" {{ block.shopify_attributes }}>
                {%- case block.settings.icon -%}
                  {%- when 'truck' -%}
                    {% render 'icon-truck', size: 20, color: '#059669' %}
                  {%- when 'shield' -%}
                    {% render 'icon-shield', size: 20, color: '#059669' %}
                  {%- when 'star' -%}
                    {% render 'icon-star', size: 20, color: '#FBBF24' %}
                {%- endcase -%}
                <span>{{ block.settings.text }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- comment -%} Full Description {%- endcomment -%}
        {%- if product.description != blank -%}
          <div class="product-page__description">
            <details class="product-page__accordion" open>
              <summary class="product-page__accordion-trigger">
                <span>{{ 'products.product.description' | t }}</span>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="4 6 8 10 12 6"></polyline>
                </svg>
              </summary>
              <div class="product-page__accordion-content rte">
                {{ product.description }}
              </div>
            </details>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{%- comment -%} Product JSON for variant switching {%- endcomment -%}
<script>
  window.productJSON = {{ product | json }};
</script>

{% schema %}
{
  "name": "Product Page",
  "tag": "div",
  "class": "product-page-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_short_desc",
      "label": "Show short description above variants",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Shipping" },
            { "value": "shield", "label": "Guarantee" },
            { "value": "star", "label": "Star" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free Shipping"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Page",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "truck",
            "text": "Free Shipping in the US"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "shield",
            "text": "30-Day Money-Back Guarantee"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "star",
            "text": "4.9★ from 2,000+ Happy Customers"
          }
        }
      ]
    }
  ]
}
{% endschema %}
