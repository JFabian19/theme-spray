{{ 'section-use-cases.css' | asset_url | stylesheet_tag }}

<section
  class="use-cases section-spacing"
  id="use-cases-{{ section.id }}"
  style="
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-heading" data-animate>{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="section-subheading" data-animate>{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="use-cases__grid grid grid--3">
      {%- for block in section.blocks -%}
        <div class="use-cases__card card" data-animate {{ block.shopify_attributes }}>
          <div class="use-cases__image-wrap">
            {%- if block.settings.image != blank -%}
              <img
                class="use-cases__image card__image"
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.title | escape }}"
                width="800"
                height="{{ 800 | divided_by: block.settings.image.aspect_ratio | round }}"
                loading="lazy"
              >
            {%- else -%}
              <div class="use-cases__placeholder card__image">
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}

            {%- comment -%} Overlay gradient {%- endcomment -%}
            <div class="use-cases__overlay"></div>

            {%- comment -%} Overlay text on image for visual impact {%- endcomment -%}
            <div class="use-cases__overlay-text">
              <h3 class="use-cases__title">{{ block.settings.title }}</h3>
            </div>
          </div>

          <div class="card__body use-cases__body">
            <h3 class="use-cases__title use-cases__title--below">{{ block.settings.title }}</h3>
            <p class="use-cases__text">{{ block.settings.text }}</p>
            {%- if block.settings.link_text != blank -%}
              <a href="{{ block.settings.link_url }}" class="use-cases__link">
                {{ block.settings.link_text }}
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="2" y1="8" x2="14" y2="8"></line>
                  <polyline points="9 3 14 8 9 13"></polyline>
                </svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Use Cases",
  "tag": "div",
  "class": "use-cases-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for Every Project"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From the garage to the craft room — SprayPro makes every job easier."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "use_case",
      "name": "Use Case",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Use Case Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Describe how the product is used in this scenario."
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link text (optional)"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Use Cases",
      "category": "Features",
      "blocks": [
        {
          "type": "use_case",
          "settings": {
            "title": "Auto & Garage",
            "text": "Ideal for painting wheels, bumpers, or restoring suspension parts."
          }
        },
        {
          "type": "use_case",
          "settings": {
            "title": "Home Improvement",
            "text": "Quickly refurbish old furniture, fences, or metal fixtures around the house."
          }
        },
        {
          "type": "use_case",
          "settings": {
            "title": "Arts & Crafts",
            "text": "Perfect for precise, detailed spray paint projects without the mess."
          }
        }
      ]
    }
  ]
}
{% endschema %}
