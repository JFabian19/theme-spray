{{ 'section-social-proof.css' | asset_url | stylesheet_tag }}

<section
  class="social-proof section-spacing"
  id="social-proof-{{ section.id }}"
  style="
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-heading" data-animate>{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="section-subheading" data-animate>{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="social-proof__layout">
      {%- comment -%} Reviews {%- endcomment -%}
      <div class="social-proof__reviews">
        {%- for block in section.blocks -%}
          {%- if block.type == 'review' -%}
            <div class="social-proof__review-card" data-animate {{ block.shopify_attributes }}>
              <div class="social-proof__stars">
                {% render 'star-rating', rating: block.settings.stars %}
              </div>
              <blockquote class="social-proof__quote">
                "{{ block.settings.review_text }}"
              </blockquote>
              <div class="social-proof__reviewer">
                {%- if block.settings.reviewer_image != blank -%}
                  <img
                    class="social-proof__reviewer-avatar"
                    src="{{ block.settings.reviewer_image | image_url: width: 80 }}"
                    alt="{{ block.settings.reviewer_name }}"
                    width="40"
                    height="40"
                    loading="lazy"
                  >
                {%- else -%}
                  <div class="social-proof__reviewer-avatar social-proof__reviewer-avatar--placeholder">
                    {{ block.settings.reviewer_name | slice: 0 }}
                  </div>
                {%- endif -%}
                <div>
                  <span class="social-proof__reviewer-name">{{ block.settings.reviewer_name }}</span>
                  {%- if block.settings.reviewer_label != blank -%}
                    <span class="social-proof__reviewer-label">{{ block.settings.reviewer_label }}</span>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%} Guarantee Block {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'guarantee' -%}
          <div class="social-proof__guarantee" data-animate {{ block.shopify_attributes }}>
            <div class="social-proof__guarantee-icon">
              {% render 'icon-shield', size: 56, color: '#059669' %}
            </div>
            <h3 class="social-proof__guarantee-title">{{ block.settings.title }}</h3>
            <p class="social-proof__guarantee-text">{{ block.settings.text }}</p>

            {%- if block.settings.button_text != blank -%}
              <a href="{{ block.settings.button_link }}" class="btn btn--primary btn--large social-proof__guarantee-btn">
                {{ block.settings.button_text }}
              </a>
            {%- endif -%}

            <div class="social-proof__trust-icons">
              <div class="social-proof__trust-item">
                {% render 'icon-truck', size: 24, color: '#059669' %}
                <span>{{ block.settings.trust_1 }}</span>
              </div>
              <div class="social-proof__trust-item">
                {% render 'icon-shield', size: 24, color: '#059669' %}
                <span>{{ block.settings.trust_2 }}</span>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

