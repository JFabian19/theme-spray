{{ 'section-related.css' | asset_url | stylesheet_tag }}

{%- if recommendations.products_count > 0 or section.settings.collection != blank -%}
<section class="related-products section-spacing" id="related-{{ section.id }}" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <h2 class="section-heading" data-animate>{{ section.settings.heading }}</h2>

    {%- if section.settings.subheading != blank -%}
      <p class="section-subheading" data-animate>{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="related-products__grid grid grid--4">
      {%- if recommendations.products_count > 0 -%}
        {%- for product in recommendations.products limit: section.settings.max_products -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- elsif section.settings.collection != blank -%}
        {%- for product in collections[section.settings.collection].products limit: section.settings.max_products -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Related Products",
  "tag": "div",
  "class": "related-products-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Fallback collection (if no recommendations)"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F9FAFB"
    }
  ],
  "presets": [
    {
      "name": "Related Products",
      "category": "Products"
    }
  ]
}
{% endschema %}
