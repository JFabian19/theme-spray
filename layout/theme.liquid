<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, height=device-height, minimum-scale=1.0">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  {% comment %} Preconnect to Shopify CDN {% endcomment %}
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  {% comment %} Google Fonts - Inter {% endcomment %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

  {% comment %} Theme CSS {% endcomment %}
  {{ 'base.css' | asset_url | stylesheet_tag }}

  {% comment %} Shopify required {% endcomment %}
  {{ content_for_header }}

  <style>
    :root {
      --color-primary: {{ settings.color_primary }};
      --color-primary-hover: {{ settings.color_primary_hover }};
      --color-text: {{ settings.color_text }};
      --color-text-secondary: {{ settings.color_text_secondary }};
      --color-background: {{ settings.color_background }};
      --color-surface: {{ settings.color_surface }};
      --color-border: {{ settings.color_border }};
      --color-accent: {{ settings.color_accent }};
      --color-success: {{ settings.color_success }};
      --page-width: {{ settings.page_width }}px;
      --font-scale: {{ settings.font_scale | divided_by: 100.0 }};
    }
  </style>

  <script>
    document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
  </script>
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">
  <a class="skip-to-content" href="#MainContent">
    {{ 'accessibility.skip_to_content' | t }}
  </a>

  {% comment %} Global sections (header group) {% endcomment %}
  {% sections 'header-group' %}

  <main id="MainContent" class="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  {% comment %} Cart Drawer {% endcomment %}
  <div id="CartDrawer" class="cart-drawer" aria-hidden="true">
    <div class="cart-drawer__overlay" data-cart-close></div>
    <div class="cart-drawer__content">
      <div class="cart-drawer__header">
        <h2 class="cart-drawer__title">{{ 'cart.title' | t }}</h2>
        <button class="cart-drawer__close" data-cart-close aria-label="{{ 'accessibility.close' | t }}">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="cart-drawer__body" id="CartDrawerBody">
        {% comment %} Cart items loaded dynamically {% endcomment %}
      </div>
      <div class="cart-drawer__footer" id="CartDrawerFooter">
        <div class="cart-drawer__subtotal">
          <span>{{ 'cart.subtotal' | t }}</span>
          <span id="CartDrawerSubtotal">{{ cart.total_price | money }}</span>
        </div>
        <a href="/checkout" class="btn btn--primary btn--full cart-drawer__checkout">
          {{ 'cart.checkout' | t }}
        </a>
        <a href="/cart" class="cart-drawer__continue">{{ 'cart.continue_shopping' | t }}</a>
      </div>
    </div>
  </div>

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
